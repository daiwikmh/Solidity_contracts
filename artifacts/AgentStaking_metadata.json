					"details": "MAY be emitted to signal that the domain could have changed."
				}
			},
			"kind": "dev",
			"methods": {
				"completeEscrow(bytes32)": {
					"details": "Can be called by arbiter after verifying service completion",
					"params": {
						"escrowId": "The escrow to complete"
					}
				},
				"createEscrow(address,uint256,string,bytes32)": {
					"params": {
						"agent": "Service agent address",
						"amount": "Payment amount",
						"paymentId": "Unique payment identifier to prevent replay",
						"sessionId": "Unique session identifier"
					},
					"returns": {
						"escrowId": "The created escrow ID"
					}
				},
				"depositStake(uint256)": {
					"params": {
						"amount": "Amount of USDC to stake"
					}
